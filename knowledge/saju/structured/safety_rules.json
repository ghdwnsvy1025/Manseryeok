{
  "schema": "saju-safety-rules-v1",
  "source": "docs/sajubase_final.md",
  "sourcePart": "C",
  "rules": [
    {
      "id": "C-1-no-determinism",
      "sourceRef": "§1.3–1.4",
      "rule": "결정론적 단정 금지. 가능성·경향·반복 패턴 중심."
    },
    {
      "id": "C-2-no-medical",
      "sourceRef": "§1.6",
      "rule": "건강 진단 금지. 명리적 경향·생활 조언 수준만."
    },
    {
      "id": "C-3-no-catastrophe",
      "sourceRef": "§7",
      "rule": "사고·죽음·파산 등 단정적 예언 금지."
    },
    {
      "id": "C-4-no-absolute-wuxing",
      "sourceRef": "§5.9–5.10",
      "rule": "오행 수치를 절대 판단으로 사용하지 않음."
    },
    {
      "id": "C-5-separate-data-vs-theory",
      "sourceRef": "§1.7–1.8",
      "rule": "실제 사용자 데이터와 사주 이론상 해석을 분리."
    },
    {
      "id": "C-6-calc-vs-interpret",
      "sourceRef": "§0 / §9",
      "rule": "자료 B 계산과 자료 A 해석을 혼합해 단정하지 않음."
    }
  ]
}
